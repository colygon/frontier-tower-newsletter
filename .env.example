# Frontier Tower — Luma SaaS Integration Platform
# Copy to .env.local and fill in your values

# ============================================================
# Luma Integration
# ============================================================
LUMA_API_KEY=your_luma_api_key_here
LUMA_SOURCE_URLS=https://luma.com/frontiertower/events
LUMA_LOOKAHEAD_DAYS=30

# ============================================================
# Email (SendGrid) — replaces Luma invites
# ============================================================
SENDGRID_API_KEY=your_sendgrid_api_key_here
FROM_EMAIL=events@frontier-tower.com
FROM_NAME="Frontier Tower Events"

# ============================================================
# Telegram
# ============================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_DEFAULT_CHAT_ID=-1001234567890

# ============================================================
# CRM Integration
# Options: twenty | attio | hubspot | salesforce | none
# ============================================================
CRM_PROVIDER=twenty
CRM_API_KEY=your_crm_api_key
CRM_BASE_URL=

# Twenty CRM (recommended built-in, https://twenty.com)
TWENTY_API_KEY=your_twenty_api_key
TWENTY_BASE_URL=http://localhost:3000

# ============================================================
# Hi.Events — Event pages & ticketing (https://hi.events)
# ============================================================
HI_EVENTS_API_KEY=your_hi_events_api_key
HI_EVENTS_BASE_URL=http://localhost:8080

# ============================================================
# Contact Enrichment — Apollo.io
# ============================================================
APOLLO_API_KEY=your_apollo_api_key_here

# ============================================================
# Social / DevRel Tracking
# ============================================================
GITHUB_TOKEN=your_github_personal_access_token
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ============================================================
# Tavily — AI-powered search for social post detection
# ============================================================
TAVILY_API_KEY=your_tavily_api_key

# ============================================================
# Apify — Web scraping for social monitoring
# ============================================================
APIFY_API_TOKEN=your_apify_api_token

# ============================================================
# OpenClaw — Multi-channel AI automation
# (https://github.com/openclaw/openclaw)
# ============================================================
OPENCLAW_BASE_URL=http://localhost:3100
OPENCLAW_API_KEY=your_openclaw_api_key

# ============================================================
# Nebius Managed PostgreSQL
# ============================================================
# Private endpoint (service-to-service within Nebius network):
#   private-rw.postgresql-e00c9be8vdp8rx0dn3.backbone-e00qegmfj4yxpj4fgj.msp.eu-north1.nebius.cloud
# Public endpoint (external access / dev):
#   public-rw.postgresql-e00c9be8vdp8rx0dn3.backbone-e00qegmfj4yxpj4fgj.msp.eu-north1.nebius.cloud
NEBIUS_PG_USER=eventsy
NEBIUS_PG_PASSWORD=your_pg_password
NEBIUS_PG_PORT=5432

# ============================================================
# Platform Settings
# ============================================================
# Local dev: sqlite://data/platform.db
# Production: postgres://eventsy:<pass>@<nebius-pg-host>:5432/eventsy?sslmode=require
DATABASE_URL=sqlite://data/platform.db
REVIEW_WINDOW_HOURS=24
NETWORK_ENABLED=true
ORG_ID=default-org
DATA_DIR=data

# Topic classification keywords (JSON)
TOPIC_KEYWORDS_JSON={"Neuro tech":["neuro","neuroscience","brain","biotech"],"AI":["ai","artificial intelligence","ml","llm","agent"],"Crypto":["crypto","blockchain","web3","defi"],"DevTools":["developer","devtools","sdk","api","open source"],"Cloud":["cloud","aws","gcp","azure","kubernetes"]}
